<div class="toast-container" id="toastContainer"></div>

<script>
// ══════════════════════════════════════════════════════
// CONFIG
// ══════════════════════════════════════════════════════
const API_URL = 'https://script.google.com/macros/s/AKfycbzaaerk9g1JWGOjXKfrm3m9Knr1OEohRxoMSio3imj8K3xF5RgrC4FL8WWbnzlv4Mr8/exec';

const PARTS_EMAIL = 'parts@narrowaisle.co.uk';

// ══════════════════════════════════════════════════════
// STATE
// ══════════════════════════════════════════════════════
let allParts = [], filteredParts = [], cart = [], isUrgent = false;
let lastOrderData = null;

// ══════════════════════════════════════════════════════
// INIT
// ══════════════════════════════════════════════════════
document.addEventListener('DOMContentLoaded', async () => {
    window.addEventListener('online',  () => document.getElementById('offlineBar').style.display = 'none');
    window.addEventListener('offline', () => document.getElementById('offlineBar').style.display = 'block');
    if (!navigator.onLine) document.getElementById('offlineBar').style.display = 'block';

    document.getElementById('searchInput').addEventListener('input', doSearch);
    loadCartFromStorage();
    await loadParts();
    renderCart();
});

// ══════════════════════════════════════════════════════
// PARTS LOADING
// ══════════════════════════════════════════════════════
async function loadParts() {
    try {
        const res = await fetch(`${API_URL}?action=getAllParts`);
        const data = await res.json();
        if (data.success && data.parts?.length) {
            allParts = data.parts.map(normalisePart);
            cacheParts(allParts);
            return;
        }
    } catch(e) {}
    // Try cache
    try {
        const cached = localStorage.getItem('flexi-parts-offline');
        if (cached) { allParts = JSON.parse(cached); toast('Showing cached parts catalogue'); }
    } catch(e) {}
}

function normalisePart(p) {
    return {
        num:  p['Part Number']   || p.partNum      || p.partNumber   || p['part number'] || '',
        desc: p['Description']   || p.desc         || p.description  || '',
        sup:  p['Supplier Code'] || p.supplier     || p.supplierCode || '',
        sys:  p['System']        || p.system        || '',
        stk:  p['Stock Level']   || p.stockLevel   || '',
        cost: p['Cost'] || p.cost || p['Price'] || p.price || '',
        _raw: p
    };
}

function cacheParts(parts) {
    try { localStorage.setItem('flexi-parts-offline', JSON.stringify(parts.map(p => ({ 'Part Number':p.num,'Description':p.desc,'Supplier Code':p.sup,'System':p.sys,'Stock Level':p.stk }))));} catch(e){}
}

// ══════════════════════════════════════════════════════
// SEARCH
// ══════════════════════════════════════════════════════
const NL_MAP = {
    mast: ['mast','vna','lift','rail'], transmission: ['transmission','trans','gearbox','gear','axle','drive','helical','intermediate'],
    hydraulic: ['hydraulic','hyd','pump','cylinder','valve','seal','oil','fluid'], electrical: ['electrical','electric','motor','wiring','cable','sensor','switch','solenoid'],
    brake: ['brake','braking','friction','pad'], fork: ['fork','pin','attachment','carriage'],
    wheel: ['wheel','tyre','tire','bearing','hub'], pipe: ['pipe','tube','hose'],
    seal: ['seal','o-ring','gasket','ring'], bolt: ['bolt','screw','nut','washer','fastener'],
    'pin kit': ['pin','kit'], 'drive axle': ['axle','drive','spacer','wheel','transmission']
};
const STOPS = new Set(['something','for','the','a','an','of','to','in','on','with','and','or','part','parts','i','need','want','get','find','show','me','some','any']);

function doSearch() {
    const raw = document.getElementById('searchInput').value;
    const term = raw.toLowerCase().trim();
    const nlBar = document.getElementById('nlBar');
    const info = document.getElementById('resultsInfo');
    if (!term) { info.style.display='none'; nlBar.style.display='none'; renderEmpty(); return; }

    info.style.display = 'block';
    let nlResult = null;
    if (term.includes(' ') || /^[a-z]{4,}$/.test(term)) nlResult = nlParse(term);

    if (nlResult) {
        nlBar.style.display = 'flex'; document.getElementById('nlBarText').textContent = nlResult.label;
        filteredParts = allParts.filter(p => nlResult.kw.some(k => (p.desc+p.sys+p.num).toLowerCase().includes(k)));
    } else {
        nlBar.style.display = 'none';
        const clean = term.replace(/[\s\-.]/g,'');
        filteredParts = allParts.filter(p => {
            const n = p.num.toLowerCase(), d = p.desc.toLowerCase(), s = p.sup.toLowerCase(), y = p.sys.toLowerCase();
            return n.replace(/[\s\-.]/g,'').includes(clean)||n.includes(term)||d.includes(term)||s.includes(term)||y.includes(term);
        });
    }
    document.getElementById('resultsCount').textContent = filteredParts.length;
    renderParts();
}

function nlParse(raw) {
    for (const [phrase, kw] of Object.entries(NL_MAP)) {
        if (raw.includes(phrase)) return { kw, label: `Searching for parts related to "${phrase}"` };
    }
    const tokens = raw.split(/\s+/).filter(t => t.length > 1 && !STOPS.has(t));
    if (!tokens.length) return null;
    let expanded = [...tokens], matched = [];
    tokens.forEach(tok => { for (const [ph, kw] of Object.entries(NL_MAP)) { if (ph.includes(tok) || tok.includes(ph.split(' ')[0])) { expanded = [...new Set([...expanded,...kw])]; matched.push(ph); }}});
    return { kw: expanded, label: matched.length ? `Interpreting as: ${[...new Set(matched)].join(', ')}` : `Searching: ${tokens.join(', ')}` };
}

function qs(term) { document.getElementById('searchInput').value = term; doSearch(); }

function renderEmpty() {
    document.getElementById('partsList').innerHTML = `
        <div class="empty-search">
            <div class="empty-search-icon">🔍</div>
            <h3>Search the Catalogue</h3>
            <p>Enter a part number, description, or use natural language to find what you need.</p>
        </div>`;
}

function renderParts() {
    const el = document.getElementById('partsList');
    if (!filteredParts.length) { el.innerHTML = '<div class="empty-search"><div class="empty-search-icon">🔎</div><h3>No parts found</h3><p>Try a different search term or browse using the quick filters above.</p></div>'; return; }
    const show = filteredParts.slice(0, 80);
    el.innerHTML = show.map(p => {
        const inCart = cart.some(c => c.num === p.num);
        const meta = [p.sup && `<span class="ptag">Supplier: ${p.sup}</span>`, p.sys && `<span class="ptag">${p.sys}</span>`, p.stk && `<span class="ptag">Stock: ${p.stk}</span>`].filter(Boolean).join('');
        return `<div class="part-row">
            <div>
                <div class="pn">${p.num || 'N/A'}</div>
                <div class="pd">${p.desc || 'No description'}</div>
                ${meta ? `<div class="pmeta">${meta}</div>` : ''}
            </div>
            <button class="add-btn ${inCart?'added':''}" id="addbtn-${CSS.escape(p.num)}" onclick='addToCart(${JSON.stringify(p)})'>${inCart ? '✓ Added' : '+ Add'}</button>
        </div>`;
    }).join('') + (filteredParts.length > 80 ? `<div style="padding:20px;text-align:center;color:var(--text-light);font-size:.88em;">Showing 80 of ${filteredParts.length} — refine your search for more specific results</div>` : '');
}

// ══════════════════════════════════════════════════════
// CART
// ══════════════════════════════════════════════════════
function addToCart(p) {
    const ex = cart.find(c => c.num === p.num);
    if (ex) { ex.qty++; } else { cart.push({ ...p, qty: 1 }); }
    saveCart(); renderCart(); updateAddBtn(p.num, true); toast(`${p.num} added to cart`);
    if (navigator.vibrate) navigator.vibrate(15);
}

function updateAddBtn(num, added) {
    const btn = document.getElementById(`addbtn-${CSS.escape(num)}`);
    if (btn) { btn.textContent = added ? '✓ Added' : '+ Add'; btn.className = `add-btn ${added?'added':''}`; }
}

function removeFromCart(i) {
    const num = cart[i].num; cart.splice(i,1); saveCart(); renderCart();
    updateAddBtn(num, false);
}

function updateQty(i, delta) {
    cart[i].qty = Math.max(1, cart[i].qty + delta);
    saveCart(); renderCart();
}

function qtyDirect(i, val) {
    cart[i].qty = Math.max(1, parseInt(val)||1);
    saveCart(); renderCart();
}

function renderCart() {
    const el = document.getElementById('cartItems');
    const cnt = cart.reduce((s,c) => s+c.qty, 0);
    document.getElementById('cartCount').textContent = cart.length;
    document.getElementById('cartHeadCount').textContent = `${cart.length} item${cart.length!==1?'s':''}`;
    document.getElementById('orderFormPanel').style.display = cart.length ? 'block' : 'none';

    if (!cart.length) {
        el.innerHTML = `<div class="cart-empty-state"><div class="cart-empty-state-icon">📦</div><p>Add parts from the catalogue to get started</p></div>`;
        return;
    }
    el.innerHTML = cart.map((c,i) => `
        <div class="cart-item">
            <div>
                <div class="ci-num">${c.num}</div>
                <div class="ci-desc">${c.desc}</div>
                <div class="ci-controls">
                    <button class="qty-btn" onclick="updateQty(${i},-1)">−</button>
                    <input class="qty-val" type="number" value="${c.qty}" min="1" onchange="qtyDirect(${i},this.value)" style="width:36px;">
                    <button class="qty-btn" onclick="updateQty(${i},1)">+</button>
                    <span style="color:var(--text-light);font-size:.8em;margin-left:4px;">× ${c.qty}</span>
                </div>
            </div>
            <button class="ci-remove" onclick="removeFromCart(${i})" title="Remove">✕</button>
        </div>`).join('');
}

function saveCart() { try { localStorage.setItem('flexi-ext-cart', JSON.stringify(cart)); } catch(e){} }
function loadCartFromStorage() { try { cart = JSON.parse(localStorage.getItem('flexi-ext-cart')||'[]'); } catch(e){ cart=[]; } }
function scrollToCart() { document.getElementById('sidebarAnchor').scrollIntoView({ behavior:'smooth' }); }

// ══════════════════════════════════════════════════════
// URGENT
// ══════════════════════════════════════════════════════
function toggleUrgent() {
    isUrgent = !isUrgent;
    document.getElementById('urgentRow').classList.toggle('on', isUrgent);
    document.getElementById('urgentCheck').textContent = isUrgent ? '✓' : '⚑';
}

// ══════════════════════════════════════════════════════
// SUBMIT ORDER
// ══════════════════════════════════════════════════════
async function submitOrder() {
    const company = document.getElementById('fCompany').value.trim();
    const contact = document.getElementById('fContact').value.trim();
    const email   = document.getElementById('fEmail').value.trim();
    if (!company) { toast('Please enter your company name'); document.getElementById('fCompany').focus(); return; }
    if (!contact) { toast('Please enter your contact name'); document.getElementById('fContact').focus(); return; }
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { toast('Please enter a valid email address'); document.getElementById('fEmail').focus(); return; }
    if (!cart.length) { toast('Your cart is empty'); return; }

    const btn = document.getElementById('submitBtn');
    btn.disabled = true; btn.textContent = 'Preparing order…';

    const serial   = document.getElementById('fSerial').value.trim();
    const orderNum = serial
        ? `${serial.toUpperCase()}-${String(Math.floor(Math.random()*1000)).padStart(3,'0')}`
        : `EXT-${String(Math.floor(Date.now()%1000000)).padStart(6,'0')}`;

    const orderData = {
        action: 'submitOrder',
        orderNumber: orderNum,
        serviceController: `${contact} (${company})`,
        company, contact, email,
        phone:           document.getElementById('fPhone').value.trim(),
        machineSerial:   serial,
        model:           document.getElementById('fModel').value,
        worksOrder:      document.getElementById('fPO').value.trim(),
        deliveryAddress: document.getElementById('fAddress').value.trim(),
        comments:        document.getElementById('fNotes').value.trim(),
        parts: cart.map(c => ({ 'Part Number': c.num, 'Description': c.desc, qty: c.qty })),
        urgent: isUrgent,
        source: 'external-portal'
    };

    lastOrderData = { ...orderData, orderDate: new Date().toLocaleString('en-GB') };

    try {
        // 1 — Send to Google Sheets
        const res = await fetch(API_URL, { method: 'POST', body: JSON.stringify(orderData) });
        const result = await res.json();
        if (!result.success) throw new Error('API error');
    } catch(e) {
        // Non-fatal — log and continue so the customer can still get their PDF + email
        console.warn('Sheets submit failed:', e);
    }

    // 2 — Generate & auto-download the PDF
    generateOrderPDF(lastOrderData, false);

    // 3 — Open mailto in their email client, PDF body summary pre-filled
    openMailto(lastOrderData);

    // 4 — Show success screen
    document.getElementById('successOrderNum').textContent = orderNum;
    document.getElementById('successOverlay').classList.add('show');
    cart = []; saveCart(); renderCart();

    btn.disabled = false; btn.textContent = 'Submit Order →';
}

// Build and fire the mailto link — opens Outlook / Gmail / Apple Mail etc.
function openMailto(data) {
    const urgentFlag = data.urgent ? '⚑ URGENT ORDER\n\n' : '';
    const partsLines = data.parts.map((p, i) =>
        `  ${i+1}. ${p['Part Number']||p.num}  —  ${p['Description']||p.desc}  (Qty: ${p.qty})`
    ).join('\n');

    const body = [
        `${urgentFlag}ORDER REFERENCE: ${data.orderNumber}`,
        `Date: ${data.orderDate}`,
        '',
        '── CUSTOMER DETAILS ──────────────────────',
        `Company:      ${data.company}`,
        `Contact:      ${data.contact}`,
        `Email:        ${data.email}`,
        `Phone:        ${data.phone || 'Not provided'}`,
        '',
        '── MACHINE DETAILS ───────────────────────',
        `Serial No:    ${data.machineSerial || 'Not provided'}`,
        `Model:        ${data.model || 'Not provided'}`,
        `PO / Ref:     ${data.worksOrder || 'Not provided'}`,
        `Delivery:     ${data.deliveryAddress || 'Not provided'}`,
        '',
        '── PARTS REQUIRED ────────────────────────',
        partsLines,
        '',
        `Total: ${data.parts.length} line item(s)`,
        '',
        data.comments ? `── NOTES ─────────────────────────────────\n${data.comments}\n` : '',
        '──────────────────────────────────────────',
        'A PDF copy of this order has been saved to your device.',
        'Please attach it to this email before sending.',
        '',
        'This order was submitted via the Flexi Parts External Portal.',
    ].join('\n');

    const subject = `${data.urgent ? '[URGENT] ' : ''}Parts Order ${data.orderNumber} — ${data.company}`;

    const mailto = `mailto:${PARTS_EMAIL}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
    window.location.href = mailto;
}

// ══════════════════════════════════════════════════════
// PDF GENERATION  (jsPDF)
// ══════════════════════════════════════════════════════
function generateOrderPDF(data, returnBase64 = false) {
    const { jsPDF } = window.jspdf;
    const doc = new jsPDF({ orientation: 'portrait', unit: 'mm', format: 'a4' });

    const W = 210, margin = 18, colR = W - margin;
    let y = 0;

    // ── RED HEADER BAND ──
    doc.setFillColor(220, 38, 38);
    doc.rect(0, 0, W, 44, 'F');

    // Logo text (white)
    doc.setTextColor(255, 255, 255);
    doc.setFont('helvetica', 'bold');
    doc.setFontSize(26);
    doc.text('FLEXI', margin, 20);
    doc.setFontSize(9);
    doc.setFont('helvetica', 'normal');
    doc.text('NARROW AISLE LTD — PARTS ORDER PORTAL', margin, 28);

    // Order number top right
    doc.setFont('helvetica', 'bold');
    doc.setFontSize(11);
    doc.text(data.orderNumber, colR, 20, { align: 'right' });
    doc.setFontSize(8);
    doc.setFont('helvetica', 'normal');
    doc.text(data.orderDate || new Date().toLocaleString('en-GB'), colR, 28, { align: 'right' });
    if (data.urgent) {
        doc.setFillColor(255, 255, 255);
        doc.roundedRect(colR - 34, 32, 34, 8, 2, 2, 'F');
        doc.setTextColor(220, 38, 38);
        doc.setFont('helvetica', 'bold');
        doc.setFontSize(7.5);
        doc.text('⚑  URGENT ORDER', colR - 17, 37.5, { align: 'center' });
    }

    y = 56;
    doc.setTextColor(26, 25, 24);

    // ── SECTION: CUSTOMER DETAILS ──
    sectionHead(doc, 'Customer Details', margin, y); y += 8;
    const col1x = margin, col2x = W / 2 + 4;

    fieldRow(doc, 'Company', data.company, col1x, y);
    fieldRow(doc, 'Contact', data.contact, col2x, y); y += 8;
    fieldRow(doc, 'Email', data.email, col1x, y);
    fieldRow(doc, 'Phone', data.phone || '—', col2x, y); y += 8;
    if (data.deliveryAddress) {
        fieldRow(doc, 'Delivery Address', data.deliveryAddress, col1x, y); y += 8;
    }
    y += 2;

    // ── SECTION: MACHINE DETAILS ──
    sectionHead(doc, 'Machine Details', margin, y); y += 8;
    fieldRow(doc, 'Serial Number', data.machineSerial || '—', col1x, y);
    fieldRow(doc, 'Model', data.model || '—', col2x, y); y += 8;
    if (data.worksOrder) { fieldRow(doc, 'PO / Reference', data.worksOrder, col1x, y); y += 8; }
    y += 2;

    // ── SECTION: PARTS ──
    sectionHead(doc, 'Parts Ordered', margin, y); y += 8;

    // Table header
    doc.setFillColor(245, 244, 242);
    doc.rect(margin, y, colR - margin, 8, 'F');
    doc.setFont('helvetica', 'bold');
    doc.setFontSize(8);
    doc.setTextColor(107, 105, 102);
    doc.text('PART NUMBER', margin + 3, y + 5.5);
    doc.text('DESCRIPTION', margin + 40, y + 5.5);
    doc.text('QTY', colR - 3, y + 5.5, { align: 'right' });
    y += 8;

    doc.setFont('helvetica', 'normal');
    doc.setFontSize(9);
    let totalQty = 0;
    data.parts.forEach((part, idx) => {
        const partNum = part['Part Number'] || part.num || '';
        const partDesc = part['Description'] || part.desc || '';
        const qty = part.qty || 1;
        totalQty += qty;
        if (idx % 2 === 0) { doc.setFillColor(252, 251, 250); doc.rect(margin, y, colR - margin, 7.5, 'F'); }
        doc.setTextColor(220, 38, 38);
        doc.setFont('helvetica', 'bold');
        doc.text(String(partNum), margin + 3, y + 5);
        doc.setTextColor(26, 25, 24);
        doc.setFont('helvetica', 'normal');
        const descTrunc = partDesc.length > 60 ? partDesc.slice(0,58)+'…' : partDesc;
        doc.text(descTrunc, margin + 40, y + 5);
        doc.text(String(qty), colR - 3, y + 5, { align: 'right' });
        y += 7.5;
        if (y > 260) { doc.addPage(); y = margin; }
    });

    // Total row
    doc.setFillColor(220, 38, 38);
    doc.rect(margin, y, colR - margin, 8, 'F');
    doc.setTextColor(255, 255, 255);
    doc.setFont('helvetica', 'bold');
    doc.setFontSize(9);
    doc.text(`${data.parts.length} line item${data.parts.length!==1?'s':''} — Total qty: ${totalQty}`, margin + 3, y + 5.5);
    y += 12;

    // Notes
    if (data.comments) {
        sectionHead(doc, 'Notes', margin, y); y += 8;
        doc.setFont('helvetica', 'normal');
        doc.setFontSize(9);
        doc.setTextColor(80, 80, 80);
        const lines = doc.splitTextToSize(data.comments, colR - margin - 3);
        doc.text(lines, margin + 3, y);
        y += lines.length * 5 + 4;
    }

    // ── FOOTER ──
    const footerY = 284;
    doc.setDrawColor(226, 224, 220);
    doc.line(margin, footerY - 4, colR, footerY - 4);
    doc.setFont('helvetica', 'normal');
    doc.setFontSize(7.5);
    doc.setTextColor(155, 152, 149);
    doc.text('Narrow Aisle Ltd  |  parts@narrowaisle.co.uk  |  www.flexi.co.uk', W/2, footerY + 1, { align: 'center' });
    doc.text(`Generated ${new Date().toLocaleString('en-GB')}`, W/2, footerY + 6, { align: 'center' });

    if (returnBase64) return doc.output('datauristring');
    doc.save(`Flexi-Parts-Order-${data.orderNumber}.pdf`);
}

function sectionHead(doc, title, x, y) {
    doc.setFont('helvetica', 'bold');
    doc.setFontSize(8.5);
    doc.setTextColor(220, 38, 38);
    doc.text(title.toUpperCase(), x, y);
    doc.setDrawColor(220, 38, 38);
    doc.setLineWidth(0.4);
    doc.line(x + doc.getTextWidth(title.toUpperCase()) + 3, y - 0.5, 210 - x, y - 0.5);
    doc.setLineWidth(0.2);
}

function fieldRow(doc, label, value, x, y) {
    doc.setFont('helvetica', 'bold');
    doc.setFontSize(7.5);
    doc.setTextColor(155, 152, 149);
    doc.text(label.toUpperCase(), x, y);
    doc.setFont('helvetica', 'normal');
    doc.setFontSize(9);
    doc.setTextColor(26, 25, 24);
    const maxW = 80;
    const valStr = String(value||'—');
    doc.text(valStr.length > 35 ? valStr.slice(0,33)+'…' : valStr, x, y + 5);
}

function downloadPDF() {
    if (lastOrderData) generateOrderPDF(lastOrderData, false);
}



// ══════════════════════════════════════════════════════
// BULK IMPORT
// ══════════════════════════════════════════════════════
function openBulk() { document.getElementById('bulkOverlay').classList.add('show'); document.getElementById('bulkTa').value=''; document.getElementById('bulkResult').classList.remove('show'); }
function closeBulk() { document.getElementById('bulkOverlay').classList.remove('show'); }

function processBulk() {
    const lines = document.getElementById('bulkTa').value.split('\n').map(l=>l.trim()).filter(Boolean);
    const res = document.getElementById('bulkResult');
    if (!lines.length) { res.innerHTML='<span style="color:#dc2626;">No part numbers entered.</span>'; res.classList.add('show'); return; }
    let found=0, notFound=[];
    lines.forEach(num => {
        const clean = num.replace(/[\s\-.]/g,'').toLowerCase();
        const p = allParts.find(x => x.num.replace(/[\s\-.]/g,'').toLowerCase()===clean || x.num.toLowerCase()===num.toLowerCase());
        if (p) { addToCart(p); found++; } else notFound.push(num);
    });
    let html = `<p style="color:#16a34a;margin-bottom:6px;font-weight:600;">✓ Added ${found} parts to cart</p>`;
    if (notFound.length) html += `<p style="color:#d97706;margin-bottom:4px;font-weight:600;">⚠ Not found: ${notFound.join(', ')}</p>`;
    res.innerHTML = html; res.classList.add('show');
    if (found) setTimeout(() => { closeBulk(); toast(`${found} parts added to cart`); }, 1800);
}

// ══════════════════════════════════════════════════════
// MISC
// ══════════════════════════════════════════════════════
function newOrder() {
    document.getElementById('successOverlay').classList.remove('show');
    lastOrderData = null; isUrgent = false;
    document.getElementById('urgentRow').classList.remove('on');
    document.getElementById('urgentCheck').textContent = '⚑';
    ['fCompany','fContact','fEmail','fPhone','fSerial','fPO','fAddress','fNotes'].forEach(id => document.getElementById(id).value='');
    document.getElementById('fModel').value = '';
    window.scrollTo({ top: 0, behavior: 'smooth' });
}

function toast(msg) {
    const el = document.createElement('div');
    el.className = 'toast'; el.textContent = msg;
    document.getElementById('toastContainer').appendChild(el);
    setTimeout(() => el.remove(), 3000);
}

// Close overlays on backdrop click
document.querySelectorAll('.overlay').forEach(o => {
    o.addEventListener('click', e => { if (e.target === o) o.classList.remove('show'); });
});
